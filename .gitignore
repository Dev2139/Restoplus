# Root .gitignore for RestoPlus

# Dependency directories
node_modules/
client/node_modules/
server/node_modules/

# Environment variables
.env
.env.*
!.env.example
client/.env
server/.env

# Build outputs
client/dist/
client/dist-ssr/

# Local database / storage
server/uploads/*
!server/uploads/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Editor files
.vscode/
.idea/
.DS_Store
